              "explanation": "Platzhalter-Erklärung zur richtigen Antwort."
            },
            {
              "id": "q2",
              "question": "Zweite Platzhalterfrage: Mehrfachauswahl möglich.",
              "allowMultiple": true,
              "options": [
                { "id": "q2-a", "label": "Option A", "isCorrect": true },
                { "id": "q2-b", "label": "Option B", "isCorrect": true },
                { "id": "q2-c", "label": "Option C", "isCorrect": false }
